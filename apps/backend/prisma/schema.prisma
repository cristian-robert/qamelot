generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEAD
  TESTER
  VIEWER
}

enum TestPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TestRunStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TestResultStatus {
  PASSED
  FAILED
  BLOCKED
  RETEST
  UNTESTED
}

enum MilestoneStatus {
  OPEN
  CLOSED
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  password    String
  role        Role         @default(TESTER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  testRuns    TestRun[]
  testResults TestResult[]
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  testSuites  TestSuite[]
  testPlans   TestPlan[]
  testRuns    TestRun[]
  milestones  Milestone[]
  defects     Defect[]
}

model TestSuite {
  id           String        @id @default(cuid())
  name         String
  description  String?
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id])
  parentId     String?
  parent       TestSuite?    @relation("SuiteTree", fields: [parentId], references: [id])
  children     TestSuite[]   @relation("SuiteTree")
  testRunCases TestRunCase[]
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
  @@index([parentId])
}

model TestPlan {
  id          String         @id @default(cuid())
  name        String
  description String?
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id])
  status      TestPlanStatus @default(DRAFT)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  testRuns    TestRun[]

  @@index([projectId])
}

model TestRun {
  id           String        @id @default(cuid())
  name         String
  testPlanId   String
  testPlan     TestPlan      @relation(fields: [testPlanId], references: [id])
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id])
  assignedToId String?
  assignedTo   User?         @relation(fields: [assignedToId], references: [id])
  status       TestRunStatus @default(PENDING)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  testRunCases TestRunCase[]
  testResults  TestResult[]

  @@index([testPlanId])
  @@index([projectId])
  @@index([assignedToId])
}

model TestRunCase {
  id          String       @id @default(cuid())
  testRunId   String
  testRun     TestRun      @relation(fields: [testRunId], references: [id])
  suiteId     String
  suite       TestSuite    @relation(fields: [suiteId], references: [id])
  createdAt   DateTime     @default(now())
  testResults TestResult[]

  @@unique([testRunId, suiteId])
  @@index([testRunId])
  @@index([suiteId])
}

model TestResult {
  id            String           @id @default(cuid())
  testRunCaseId String
  testRunCase   TestRunCase      @relation(fields: [testRunCaseId], references: [id])
  testRunId     String
  testRun       TestRun          @relation(fields: [testRunId], references: [id])
  executedById  String
  executedBy    User             @relation(fields: [executedById], references: [id])
  status        TestResultStatus @default(UNTESTED)
  comment       String?
  elapsed       Int?             // duration in seconds
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([testRunCaseId])
  @@index([testRunId])
  @@index([executedById])
}

model Milestone {
  id          String          @id @default(cuid())
  name        String
  description String?
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id])
  startDate   DateTime?
  dueDate     DateTime?
  status      MilestoneStatus @default(OPEN)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
}

model Defect {
  id          String    @id @default(cuid())
  reference   String
  description String?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}
