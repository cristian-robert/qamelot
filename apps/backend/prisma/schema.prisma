generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEAD
  TESTER
  VIEWER
}

enum TestPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TestRunStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TestResultStatus {
  PASSED
  FAILED
  BLOCKED
  RETEST
  UNTESTED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
  ACCEPTANCE
  EXPLORATORY
}

enum MilestoneStatus {
  OPEN
  CLOSED
}

enum CasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum CaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
  EXPLORATORY
  OTHER
}

enum TemplateType {
  TEXT
  STEPS
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  password      String
  role          Role          @default(TESTER)
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  testRuns      TestRun[]
  testResults   TestResult[]
  attachments   Attachment[]
  caseHistories CaseHistory[]
}

model Project {
  id                     String                  @id @default(cuid())
  name                   String
  description            String?
  deletedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  testSuites             TestSuite[]
  testCases              TestCase[]
  testPlans              TestPlan[]
  testRuns               TestRun[]
  milestones             Milestone[]
  defects                Defect[]
  sharedSteps            SharedStep[]
  configGroups           ConfigGroup[]
  customFieldDefinitions CustomFieldDefinition[]
}

model TestSuite {
  id           String        @id @default(cuid())
  name         String
  description  String?
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id])
  parentId     String?
  parent       TestSuite?    @relation("SuiteTree", fields: [parentId], references: [id])
  children     TestSuite[]   @relation("SuiteTree")
  testCases    TestCase[]
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
  @@index([parentId])
}

model TestCase {
  id            String         @id @default(cuid())
  title         String
  preconditions String?
  templateType  TemplateType   @default(TEXT)
  priority      CasePriority   @default(MEDIUM)
  type          CaseType       @default(FUNCTIONAL)
  estimate      Int?           // duration in seconds
  references    String?        // comma-separated references
  position      Int            @default(0)
  suiteId       String
  suite         TestSuite      @relation(fields: [suiteId], references: [id])
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  steps         TestCaseStep[]
  testRunCases  TestRunCase[]
  history       CaseHistory[]
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([suiteId])
  @@index([projectId])
  @@index([priority])
  @@index([type])
}

model CaseHistory {
  id        String   @id @default(cuid())
  caseId    String
  testCase  TestCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([userId])
}

model TestCaseStep {
  id              String           @id @default(cuid())
  caseId          String
  testCase        TestCase         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stepNumber      Int
  description     String
  expectedResult  String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  testStepResults TestStepResult[]

  @@unique([caseId, stepNumber])
  @@index([caseId])
}

model TestPlan {
  id          String         @id @default(cuid())
  name        String
  description String?
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id])
  status      TestPlanStatus @default(DRAFT)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  testRuns    TestRun[]

  @@index([projectId])
}

model TestRun {
  id           String        @id @default(cuid())
  name         String
  testPlanId   String
  testPlan     TestPlan      @relation(fields: [testPlanId], references: [id])
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id])
  assignedToId String?
  assignedTo   User?         @relation(fields: [assignedToId], references: [id])
  status       TestRunStatus @default(PENDING)
  configLabel  String?
  sourceRunId  String?
  sourceRun    TestRun?      @relation("RerunChain", fields: [sourceRunId], references: [id])
  reruns       TestRun[]     @relation("RerunChain")
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  testRunCases TestRunCase[]
  testResults  TestResult[]

  @@index([testPlanId])
  @@index([projectId])
  @@index([assignedToId])
  @@index([sourceRunId])
}

model TestRunCase {
  id          String       @id @default(cuid())
  testRunId   String
  testRun     TestRun      @relation(fields: [testRunId], references: [id])
  testCaseId  String
  testCase    TestCase     @relation(fields: [testCaseId], references: [id])
  createdAt   DateTime     @default(now())
  testResults TestResult[]

  @@unique([testRunId, testCaseId])
  @@index([testRunId])
  @@index([testCaseId])
}

model TestResult {
  id              String           @id @default(cuid())
  testRunCaseId   String
  testRunCase     TestRunCase      @relation(fields: [testRunCaseId], references: [id])
  testRunId       String
  testRun         TestRun          @relation(fields: [testRunId], references: [id])
  executedById    String
  executedBy      User             @relation(fields: [executedById], references: [id])
  status          TestResultStatus @default(UNTESTED)
  statusOverride  Boolean          @default(false)
  comment         String?
  elapsed         Int?             // duration in seconds
  defects         Defect[]
  testStepResults TestStepResult[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([testRunCaseId])
  @@index([testRunId])
  @@index([executedById])
}

model TestStepResult {
  id             String           @id @default(cuid())
  testResultId   String
  testResult     TestResult       @relation(fields: [testResultId], references: [id], onDelete: Cascade)
  testCaseStepId String
  testCaseStep   TestCaseStep     @relation(fields: [testCaseStepId], references: [id])
  status         TestResultStatus @default(UNTESTED)
  actualResult   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([testResultId, testCaseStepId])
  @@index([testResultId])
  @@index([testCaseStepId])
}

model Milestone {
  id          String          @id @default(cuid())
  name        String
  description String?
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id])
  parentId    String?
  parent      Milestone?      @relation("MilestoneTree", fields: [parentId], references: [id])
  children    Milestone[]     @relation("MilestoneTree")
  startDate   DateTime?
  dueDate     DateTime?
  status      MilestoneStatus @default(OPEN)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
  @@index([parentId])
}

model Defect {
  id           String      @id @default(cuid())
  reference    String
  description  String?
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id])
  testResultId String?
  testResult   TestResult? @relation(fields: [testResultId], references: [id])
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId])
  @@index([testResultId])
}

enum CustomFieldType {
  STRING
  NUMBER
  DROPDOWN
  CHECKBOX
  DATE
}

enum CustomFieldEntityType {
  TEST_CASE
  TEST_RESULT
}

enum AttachmentEntityType {
  TEST_CASE
  TEST_RESULT
}

model Attachment {
  id           String               @id @default(cuid())
  filename     String
  mimeType     String
  size         Int
  path         String
  entityType   AttachmentEntityType
  entityId     String
  uploadedById String
  uploadedBy   User                 @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([entityType, entityId])
  @@index([uploadedById])
}

model CustomFieldDefinition {
  id         String              @id @default(cuid())
  name       String
  fieldType  CustomFieldType
  options    Json?               // JSON array of strings for DROPDOWN type
  required   Boolean             @default(false)
  entityType CustomFieldEntityType
  projectId  String
  project    Project             @relation(fields: [projectId], references: [id])
  position   Int                 @default(0)
  deletedAt  DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  values     CustomFieldValue[]

  @@index([projectId])
  @@index([entityType])
}

model CustomFieldValue {
  id           String                @id @default(cuid())
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  entityType   CustomFieldEntityType
  entityId     String
  value        String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([definitionId, entityId])
  @@index([definitionId])
  @@index([entityType, entityId])
}

model SharedStep {
  id        String           @id @default(cuid())
  title     String
  projectId String
  project   Project          @relation(fields: [projectId], references: [id])
  items     SharedStepItem[]
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([projectId])
}

model SharedStepItem {
  id             String     @id @default(cuid())
  sharedStepId   String
  sharedStep     SharedStep @relation(fields: [sharedStepId], references: [id], onDelete: Cascade)
  stepNumber     Int
  description    String
  expectedResult String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([sharedStepId, stepNumber])
  @@index([sharedStepId])
}

model ConfigGroup {
  id        String       @id @default(cuid())
  name      String
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
  items     ConfigItem[]
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([projectId])
}

model ConfigItem {
  id        String      @id @default(cuid())
  name      String
  groupId   String
  group     ConfigGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([groupId])
}
