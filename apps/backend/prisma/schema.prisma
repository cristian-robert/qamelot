generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEAD
  TESTER
  VIEWER
}

enum TestPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TestRunStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TestResultStatus {
  PASSED
  FAILED
  BLOCKED
  RETEST
  UNTESTED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
  ACCEPTANCE
  EXPLORATORY
}

enum MilestoneStatus {
  OPEN
  CLOSED
}

enum CasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum CaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
  EXPLORATORY
  OTHER
}

enum TemplateType {
  TEXT
  STEPS
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  password    String
  role        Role         @default(TESTER)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  testRuns    TestRun[]
  testResults TestResult[]
  attachments Attachment[]
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  testSuites  TestSuite[]
  testCases   TestCase[]
  testPlans   TestPlan[]
  testRuns    TestRun[]
  milestones  Milestone[]
  defects     Defect[]
}

model TestSuite {
  id           String        @id @default(cuid())
  name         String
  description  String?
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id])
  parentId     String?
  parent       TestSuite?    @relation("SuiteTree", fields: [parentId], references: [id])
  children     TestSuite[]   @relation("SuiteTree")
  testCases    TestCase[]
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
  @@index([parentId])
}

model TestCase {
  id            String         @id @default(cuid())
  title         String
  preconditions String?
  templateType  TemplateType   @default(TEXT)
  priority      CasePriority   @default(MEDIUM)
  type          CaseType       @default(FUNCTIONAL)
  estimate      Int?           // duration in seconds
  references    String?        // comma-separated references
  position      Int            @default(0)
  suiteId       String
  suite         TestSuite      @relation(fields: [suiteId], references: [id])
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  steps         TestCaseStep[]
  testRunCases  TestRunCase[]
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([suiteId])
  @@index([projectId])
  @@index([priority])
  @@index([type])
}

model TestCaseStep {
  id             String   @id @default(cuid())
  caseId         String
  testCase       TestCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stepNumber     Int
  description    String
  expectedResult String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([caseId, stepNumber])
  @@index([caseId])
}

model TestPlan {
  id          String         @id @default(cuid())
  name        String
  description String?
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id])
  status      TestPlanStatus @default(DRAFT)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  testRuns    TestRun[]

  @@index([projectId])
}

model TestRun {
  id           String        @id @default(cuid())
  name         String
  testPlanId   String
  testPlan     TestPlan      @relation(fields: [testPlanId], references: [id])
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id])
  assignedToId String?
  assignedTo   User?         @relation(fields: [assignedToId], references: [id])
  status       TestRunStatus @default(PENDING)
  sourceRunId  String?
  sourceRun    TestRun?      @relation("RerunChain", fields: [sourceRunId], references: [id])
  reruns       TestRun[]     @relation("RerunChain")
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  testRunCases TestRunCase[]
  testResults  TestResult[]

  @@index([testPlanId])
  @@index([projectId])
  @@index([assignedToId])
  @@index([sourceRunId])
}

model TestRunCase {
  id          String       @id @default(cuid())
  testRunId   String
  testRun     TestRun      @relation(fields: [testRunId], references: [id])
  testCaseId  String
  testCase    TestCase     @relation(fields: [testCaseId], references: [id])
  createdAt   DateTime     @default(now())
  testResults TestResult[]

  @@unique([testRunId, testCaseId])
  @@index([testRunId])
  @@index([testCaseId])
}

model TestResult {
  id            String           @id @default(cuid())
  testRunCaseId String
  testRunCase   TestRunCase      @relation(fields: [testRunCaseId], references: [id])
  testRunId     String
  testRun       TestRun          @relation(fields: [testRunId], references: [id])
  executedById  String
  executedBy    User             @relation(fields: [executedById], references: [id])
  status        TestResultStatus @default(UNTESTED)
  comment       String?
  elapsed       Int?             // duration in seconds
  defects       Defect[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([testRunCaseId])
  @@index([testRunId])
  @@index([executedById])
}

model Milestone {
  id          String          @id @default(cuid())
  name        String
  description String?
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id])
  startDate   DateTime?
  dueDate     DateTime?
  status      MilestoneStatus @default(OPEN)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
}

model Defect {
  id           String      @id @default(cuid())
  reference    String
  description  String?
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id])
  testResultId String?
  testResult   TestResult? @relation(fields: [testResultId], references: [id])
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId])
  @@index([testResultId])
}

enum AttachmentEntityType {
  TEST_CASE
  TEST_RESULT
}

model Attachment {
  id           String               @id @default(cuid())
  filename     String
  mimeType     String
  size         Int
  path         String
  entityType   AttachmentEntityType
  entityId     String
  uploadedById String
  uploadedBy   User                 @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([entityType, entityId])
  @@index([uploadedById])
}
